# ------------------------------------------------------------------
# Supabase — Project Settings → API  (https://supabase.com/dashboard/project/_/settings/api)
# ------------------------------------------------------------------

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# "anon" / publishable key — safe to expose to the browser (protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "service_role" / secret key — SERVER ONLY. Bypasses RLS. Never expose to the client.
# (Optional for now; used later for privileged admin tasks.)
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------------
# AI (server-only — never exposed to the browser)
# ------------------------------------------------------------------

# Google AI Studio (aistudio.google.com/apikey) — FREE tier, no card required.
# Powers chat with files, image OCR, and auto-categorization.
GEMINI_API_KEY=

# Optional: overrides the Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=

# Optional alternative LLM provider. If GEMINI_API_KEY is set it takes priority.
# console.anthropic.com → API Keys (paid — no free tier).
ANTHROPIC_API_KEY=

# voyageai.com → API Keys. Powers embeddings for semantic search.
VOYAGE_API_KEY=

# ------------------------------------------------------------------
# App
# ------------------------------------------------------------------

# Public origin, used for share links and auth email redirects.
# Set to your production domain on Vercel (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
