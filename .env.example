# ------------------------------------------------------------------
# Supabase — Project Settings → API  (https://supabase.com/dashboard/project/_/settings/api)
# ------------------------------------------------------------------

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# "anon" / publishable key — safe to expose to the browser (protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "service_role" / secret key — SERVER ONLY. Bypasses RLS. Never expose to the client.
# (Optional for now; used later for privileged admin tasks.)
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------------
# AI (server-only — never exposed to the browser)
# ------------------------------------------------------------------

# console.groq.com/keys — FREE tier, fast, generous rate limits. Primary
# provider (checked first) for chat with files, image OCR, and
# auto-categorization.
GROQ_API_KEY=

# Optional: overrides the Groq chat / vision model. Groq's lineup changes
# often — check console.groq.com/docs/models if a default gets deprecated.
# GROQ_MODEL=
# GROQ_VISION_MODEL=

# Google AI Studio (aistudio.google.com/apikey) — FREE tier, no card required.
# Used if GROQ_API_KEY isn't set, or as an automatic fallback if Groq fails.
GEMINI_API_KEY=

# Optional: overrides the Gemini model (default: gemini-flash-latest)
# GEMINI_MODEL=

# Optional further fallback. console.anthropic.com → API Keys (paid — no
# free tier). Used only if Groq/Gemini aren't set or fail.
ANTHROPIC_API_KEY=

# voyageai.com → API Keys. Powers embeddings for semantic search.
VOYAGE_API_KEY=

# ------------------------------------------------------------------
# App
# ------------------------------------------------------------------

# Public origin, used for share links and auth email redirects.
# Set to your production domain on Vercel (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------------
# Draftly — separately-deployed Google Docs-style editor, embedded in an
# iframe for the "Open with Draftly" option on text documents. Optional:
# the option is hidden entirely if this isn't set. Deploy Draftly on its own
# and point this at its origin (see that project's SETUP.md).
# ------------------------------------------------------------------

# Origin only, no trailing slash and no /import path — e.g.
# https://draftly.your-domain.com
NEXT_PUBLIC_DRAFTLY_URL=
